<Window x:Class="DES_Project_New.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DES_Project_New"
        mc:Ignorable="d"
        Title="Chương trình Mã hóa DES - Nhóm An Ninh Mạng" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <TabControl Margin="10">

            <TabItem Header="  Tạo Khóa  " FontSize="16" Height="40">
                <Grid Background="White" Margin="0">
                    <StackPanel Margin="20" VerticalAlignment="Top">
                        <GroupBox Header="Cấu hình khóa">
                            <StackPanel>
                                <Label Content="Nhập từ khóa (ASCII: 8 ký tự | Hex: 16 ký tự):"/>

                                <StackPanel Orientation="Horizontal" Margin="0,5">

                                    <TextBox Name="txtKeyInput" Width="400" Height="35" FontSize="14" Padding="5" 
                                             Text="12345678" VerticalContentAlignment="Center"
                                             TextChanged="txtKeyInput_TextChanged"/>

                                    <ComboBox Name="cbKeyType" 
                                              Width="80" Height="35" 
                                              SelectionChanged="cbKeyType_SelectionChanged"   
                                              SelectedIndex="0" Margin="5,0,0,0" VerticalContentAlignment="Center" FontSize="13">
                                        <ComboBoxItem Content="ASCII"/>
                                        <ComboBoxItem Content="Hex"/>
                                    </ComboBox>
                                    <Button Click="ResetKey_Click" Width="40" Height="35" Margin="5,0,0,0" 
                                            Background="#DC3545" ToolTip="Làm mới / Xóa rỗng">
                                        <TextBlock Text="↺" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,-2,0,0"/>
                                    </Button>
                                </StackPanel>

                                <TextBlock Text="* ASCII: Nhập đúng 8 ký tự. Hex: Nhập đúng 16 ký tự (0-9, A-F)." FontStyle="Italic" Foreground="Gray" FontSize="11" Margin="2,2,0,10"/>

                                <Label Content="Độ dài khóa:" Margin="0,0,0,0"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="64-bit (DES Chuẩn)" IsChecked="True" Margin="0,0,20,0"/>
                                    <RadioButton Content="128-bit (Không hỗ trợ)" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <Button Click="GenerateKey_OnClick" Content="🎲 Sinh khóa" Width="261" Height="35" Margin="5,0,0,0" 
                                Background="#0078D7" Foreground="White"/>
                        <GroupBox Header="Thông tin khóa đã tạo">
                            <StackPanel>
                                <Label Content="Khóa bí mật (Secret Key):"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="txtKeyDisplay" Grid.Column="0" Height="30" FontSize="14" IsReadOnly="True" Background="#F0F0F0" Padding="5"/>
                                    <CheckBox Name="cbShowKey" FontSize="15" Grid.Column="1" Content="Hiện" VerticalAlignment="Center" Margin="10,0,0,0" Click="ShowKey_Click"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                    <Button Click="SaveFileWithKeyValueButtonWithDialog_Click" Content="📂 Lưu khóa vào tệp" Width="191" Background="#28A745" Foreground="White" Height="33"/>
                                    <Button Click="OpenFileWithKeyValueButtonWithDialog_Click" Content="📂 Nhập khóa từ tệp" Width="197" Background="#28A745" Foreground="White" Height="32"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="  Mã Hóa  " FontSize="16" Height="40">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Dữ liệu đầu vào (Bản rõ)" Grid.Row="0" Margin="10">
                        <Grid>
                            <TextBox Name="txtPlainInput" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="5" FontSize="14" BorderBrush="#CCCCCC"/>
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="1" Margin="10,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                            <Button Click="OpenFileWithPlainTextButtonWithDialog_Click" Content="Tải tệp văn bản (.txt)" Width="175" Background="#28A745" Height="35"/>
                            
                            <Button Click="SaveInputPlainText_Click" Content="Lưu bản rõ nhập (.txt)" Width="179" Background="#28A745" Margin="0,0,5,0" Height="35"/>
                        </StackPanel>

                        <Button Click="Encrypt" Content="🔒 THỰC HIỆN MÃ HÓA" Height="45" Background="#0078D7" FontSize="16"/>
                    </StackPanel>

                    <GroupBox Header="Kết quả (Bản mã - Hex)" Grid.Row="2" Margin="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox Name="txtCipherOutput" Grid.Row="0" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="5" FontSize="14" Background="#F9F9F9" Foreground="Green"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                                <Button Click="SaveFileWithCryptogramButtonWithDialog_Click" Content="Lưu kết quả vào tệp" Width="166" Background="#28A745" Height="38"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="  Giải Mã  " FontSize="16" Height="40">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Dữ liệu đầu vào (Bản mã - Hex)" Grid.Row="0" Margin="10">
                        <Grid>
                            <TextBox Name="txtCipherInput" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="5" FontSize="14" BorderBrush="#CCCCCC"/>
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="1" Margin="10,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                            <Button Click="SaveInputCipherText_Click" Content="Lưu bản mã nhập (.txt)" Width="185" Background="#28A745" Margin="0,0,5,0" Height="32"/>
                            <Button Click="OpenFileWithCryptogramButtonWithDialog_Click" Content="Tải tệp bản mã" Width="129" Background="#28A745" Height="32"/>
                        </StackPanel>

                        <Button Click="Decrypt" Content="🔓 THỰC HIỆN GIẢI MÃ" Height="45" Background="#0078D7" FontSize="16" Width="843"/>
                    </StackPanel>

                    <GroupBox Header="Kết quả giải mã (Bản rõ)" Grid.Row="2" Margin="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox Name="txtPlainOutput" Grid.Row="0" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="5" FontSize="14" Background="#F9F9F9" Margin="0,0,-9,0"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                                <Button Click="SaveFileWithPlainTextButtonWithDialog_Click" Content="Lưu văn bản (.txt)" Width="152" Background="#28A745" Height="32"/>
                                <Button Click="RebuildFile_Click" Content="Khôi phục tệp gốc" Width="146" Height="32" Background="#28A745"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>